# 手机产品参数查询与竞品分析工具 - 环境变量示例
# 复制为 .env 后按需修改

# 后端服务
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库（默认 SQLite，无需安装）
DATABASE_URL=sqlite:///./data/phone_competitor.db

# DeepSeek API（竞品分析报告必填）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=120

# 抓取
# 请求间隔过短易触发 429，建议 20～30（单位：秒）
GSMARENA_REQUEST_DELAY_SECONDS=20
GSMARENA_TIMEOUT_SECONDS=30

# 默认市场
DEFAULT_CURRENCY=CNY
DEFAULT_MARKET_REGION=CN

# 前端调用后端地址（Next.js 开发时）
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
